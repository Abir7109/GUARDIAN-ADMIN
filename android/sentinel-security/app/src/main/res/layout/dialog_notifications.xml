<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_square"
        android:backgroundTint="#0DFFFFFF"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tv_notif_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NOW"
            android:textColor="@color/primary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_square"
            android:backgroundTint="#1E4CD6FF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tv_notif_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Intrusion Attempt Blocked"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_notif_body"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Front camera captured suspect — evidence saved"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@color/primary_light"
            android:alpha="0.6" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_square"
        android:backgroundTint="#0DFFFFFF"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2m"
            android:textColor="@color/tertiary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_square"
            android:backgroundTint="#1AFFA24C"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Location Synced"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Coordinates uploaded to secure cloud"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@color/tertiary"
            android:alpha="0.6" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_square"
        android:backgroundTint="#0DFFFFFF"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1h"
            android:textColor="@color/status_red"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_square"
            android:backgroundTint="#26FF3B30"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Charger Disconnected"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Device unplugged — alarm sequence ready"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@color/status_red"
            android:alpha="0.6" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_square"
        android:backgroundTint="#0DFFFFFF"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3h"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_square"
            android:backgroundTint="#1AFFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New Device Login"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Unknown device: Galaxy S24, Seoul"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@color/text_secondary"
            android:alpha="0.4" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@drawable/bg_square"
        android:backgroundTint="#0DFFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="yest"
            android:textColor="@color/text_secondary"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:background="@drawable/bg_square"
            android:backgroundTint="#1AFFFFFF"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protection Updated"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Definitions &amp; heuristics synced v4.2"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <View
            android:layout_width="4dp"
            android:layout_height="32dp"
            android:layout_marginStart="8dp"
            android:background="@color/text_secondary"
            android:alpha="0.4" />
    </LinearLayout>

</LinearLayout>
