<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/background_dark">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <View
            android:id="@+id/top_bar"
            android:layout_width="match_parent"
            android:layout_height="4dp"
            android:background="@color/secondary"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.cardview.widget.CardView
            android:id="@+id/cv_lock_header"
            style="@style/Widget.Sentinel.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            app:strokeColor="@color/secondary"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toTopOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <ImageView
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_shield"
                    app:tint="@color/secondary"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="DEVICE LOCKED"
                    android:textColor="@color/secondary"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.08" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center"
                    android:text="Guardian protection is active. Enter your PIN to unlock the device."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/ll_pin_dots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/cv_lock_header"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <View android:id="@+id/dot1" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_input" android:backgroundTint="@color/surface_container_highest" />
            <View android:id="@+id/dot2" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_input" android:backgroundTint="@color/surface_container_highest" />
            <View android:id="@+id/dot3" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_input" android:backgroundTint="@color/surface_container_highest" />
            <View android:id="@+id/dot4" android:layout_width="16dp" android:layout_height="16dp" android:layout_margin="8dp" android:background="@drawable/bg_pin_input" android:backgroundTint="@color/surface_container_highest" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/ll_keypad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/ll_pin_dots">

            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btn_key_1" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="1" android:textColor="@color/white" android:textSize="20sp" />
                <Button android:id="@+id/btn_key_2" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:text="2" android:textColor="@color/white" android:textSize="20sp" />
                <Button android:id="@+id/btn_key_3" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="3" android:textColor="@color/white" android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btn_key_4" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="4" android:textColor="@color/white" android:textSize="20sp" />
                <Button android:id="@+id/btn_key_5" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:text="5" android:textColor="@color/white" android:textSize="20sp" />
                <Button android:id="@+id/btn_key_6" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="6" android:textColor="@color/white" android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal" android:layout_marginBottom="8dp">
                <Button android:id="@+id/btn_key_7" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="7" android:textColor="@color/white" android:textSize="20sp" />
                <Button android:id="@+id/btn_key_8" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:text="8" android:textColor="@color/white" android:textSize="20sp" />
                <Button android:id="@+id/btn_key_9" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="9" android:textColor="@color/white" android:textSize="20sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="match_parent" android:layout_height="56dp" android:orientation="horizontal">
                <View android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" />
                <Button android:id="@+id/btn_key_0" style="@style/Widget.MaterialComponents.Button.OutlinedButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_marginStart="8dp" android:layout_marginEnd="8dp" android:text="0" android:textColor="@color/white" android:textSize="20sp" />
                <Button android:id="@+id/btn_key_del" style="@style/Widget.MaterialComponents.Button.TextButton" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:text="DEL" android:textColor="@color/text_secondary" android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btn_unlock"
            style="@style/Widget.Sentinel.Button"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="24dp"
            android:text="UNLOCK"
            app:layout_constraintTop_toBottomOf="@id/ll_keypad" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
