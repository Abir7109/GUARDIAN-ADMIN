<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Custom Card styling -->
    <style name="Widget.Sentinel.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_dark</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="android:layout_marginBottom">@dimen/margin_sm</item>
    </style>

    <!-- Elevated transparent glow glass container -->
    <style name="Widget.Sentinel.GlassCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface_container</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Primary Action Button -->
    <style name="Widget.Sentinel.Button" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">@dimen/touch_target_min</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>



    <!-- Custom Alert Dialog Dark Theme -->
    <style name="AlertDialogCustom" parent="ThemeOverlay.MaterialComponents.Dialog">
        <item name="colorOnSurface">@color/white</item>
        <item name="colorSurface">@color/surface_dark</item>
    </style>

    <!-- Dark TextInput layout styling -->
    <style name="Widget.Sentinel.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">#070A14</item>
        <item name="boxCornerRadiusTopStart">8dp</item>
        <item name="boxCornerRadiusTopEnd">8dp</item>
        <item name="boxCornerRadiusBottomStart">8dp</item>
        <item name="boxCornerRadiusBottomEnd">8dp</item>
        <item name="boxStrokeColor">#33DFE2F3</item>
        <item name="android:textColorHint">@color/text_secondary</item>
        <item name="hintTextColor">@color/primary_light</item>
    </style>
</resources>
