<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.securphone.app">

    <!-- Permissions specifications -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />
    <uses-permission android:name="android.permission.READ_PHONE_STATE" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:name="com.securphone.app.SecurePhoneApp"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Sentinel"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- Splash Activity -->
        <activity
            android:name="com.securphone.app.ui.splash.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.Sentinel.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name="com.securphone.app.ui.onboarding.OnboardingActivity" />
        <activity android:name="com.securphone.app.ui.auth.LoginActivity" />
        <activity android:name="com.securphone.app.ui.auth.SignUpActivity" />
        <activity android:name="com.securphone.app.ui.setup.SetupWizardActivity" />
        <activity android:name="com.securphone.app.ui.main.MainActivity" />
        <activity
            android:name="com.securphone.app.ui.main.SafeZoneMapActivity"
            android:theme="@style/Theme.Sentinel.NoActionBar" />
        <activity android:name="com.securphone.app.ui.maintenance.MaintenanceActivity" />
        <activity android:name="com.securphone.app.ui.update.ForceUpdateActivity" />
        <activity
            android:name="com.securphone.app.ui.lock.GuardLockActivity"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true"
            android:turnScreenOn="true"
            android:theme="@style/Theme.Sentinel.NoActionBar" />

        <!-- High-Priority Lock Screen Overlay -->
        <activity
            android:name="com.securphone.app.ui.alarm.AlarmOverlayActivity"
            android:excludeFromRecents="true"
            android:launchMode="singleInstance"
            android:showOnLockScreen="true"
            android:turnScreenOn="true" />

        <!-- Core background protection engine service -->
        <service
            android:name="com.securphone.app.services.ProtectionService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="location" />

        <!-- Background siren audio service (decoupled from lock-screen overlay) -->
        <service
            android:name="com.securphone.app.services.SirenService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- Notification monitor -->
        <service
            android:name="com.securphone.app.services.NotificationMonitorService"
            android:label="Guardian Notification Monitor"
            android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.service.notification.NotificationListenerService" />
            </intent-filter>
        </service>

        <!-- Accessibility service Remote control block -->
        <service
            android:name="com.securphone.app.services.SecurePhoneAccessibilityService"
            android:label="Guardian Accessibility Block"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Cloud Coordination Service -->
        <service
            android:name="com.securphone.app.services.SecurePhoneMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>

        <!-- Auto startup on boot -->
        <receiver
            android:name="com.securphone.app.receivers.BootReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Offgrid distress sms triggers -->
        <receiver
            android:name="com.securphone.app.receivers.SmsReceiver"
            android:permission="android.permission.BROADCAST_SMS"
            android:exported="true">
            <intent-filter>
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Final location broadcast before device powers off -->
        <receiver
            android:name="com.securphone.app.receivers.ShutdownReceiver"
            android:enabled="true"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.ACTION_SHUTDOWN" />
                <action android:name="android.intent.action.QUICKBOOT_POWEROFF" />
            </intent-filter>
        </receiver>

        <!-- Secure Device Policy admin -->
        <receiver
            android:name="com.securphone.app.receivers.SecurePhoneDeviceAdmin"
            android:label="Guardian Device Policy"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_policies" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

    </application>

</manifest>
