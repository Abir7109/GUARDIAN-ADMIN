# Firebase Admin SDK Service Account
# 1. Go to Firebase Console > Project Settings > Service Accounts
# 2. Click "Generate New Private Key" → save as service-account.json
# 3. Place the file in the project root
# 4. Set the path below:
FIREBASE_SERVICE_ACCOUNT_PATH="./service-account.json"

# Your Firebase project ID (from Project Settings)
FIREBASE_PROJECT_ID="your-firebase-project-id"

# GEMINI_API_KEY: Required for Gemini AI Auditor features
# Get it from https://aistudio.google.com/app/apikey
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Comma-separated list of allowed CORS origins (for Netlify frontend)
CORS_ORIGINS="https://guardian-admin.netlify.app,http://localhost:5173,http://localhost:3000"
